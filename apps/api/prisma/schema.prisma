datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Calendar {
  id          String   @id @default(uuid())
  url         String   @unique
  name        String
  description String?
  visible     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}